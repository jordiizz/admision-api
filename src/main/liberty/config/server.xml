<?xml version="1.0" encoding="UTF-8"?>
<server description="new server">
    <!-- Enable features -->
    <featureManager>
        <feature>jakartaee-10.0</feature>
    </featureManager>
    <!-- This template enables security. To get the full use of all the capabilities, a keystore and user registry

    <!- For the keystore, default keys are generated and stored in a keystore. To provide the keystore password, g
         encoded password using bin/securityUtility encode and add it below in the password attribute of the keySto
         Then uncomment the keyStore element. -->
    <!--
    <keyStore password=""/>
    -->

    <!--For a user registry configuration, configure your user registry. For example, configure a basic user regist
        basicRegistry element. Specify your own user name below in the name attribute of the user element. For the
        generate an encoded password using bin/securityUtility encode and add it in the password attribute of the u
        Then uncomment the user element. -->
    <basicRegistry id="basic" realm="BasicRealm">
        <!-- <user name="yourUserName" password="" />  -->
    </basicRegistry>

    <!-- To access this server from a remote client add a host attribute to the following element, e.g. host="*" -->
    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="9080"
                  httpsPort="9443" />

    <!-- Automatically expand WAR files and EAR files -->
    <applicationManager autoExpand="true"/>
    <!-- Default SSL configuration enables trust for default certificates from the Java runtime -->
    <ssl id="defaultSSLConfig" trustDefaultCerts="true" />

    <!-- pool de conexiones-->
    <dataSource id="AdmisionDataSource"
                jndiName="jdbc/admision"
                jdbcDriverRef="postgresql-driver"
                type="javax.sql.ConnectionPoolDataSource"
                transactional="true">
        <properties serverName="localhost"
                    databaseName="tpi135"
                    portNumber="5432"
                    user="postgres"
                    password="abc123"
        />
    </dataSource>

</server>
